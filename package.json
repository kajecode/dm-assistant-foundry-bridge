{
  "name": "dm-assistant-bridge",
  "version": "0.11.0",
  "description": "Foundry VTT module — imports content from a running dm-assistant instance.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build",
    "package": "pnpm build && node scripts/package-zip.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.7",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "fvtt-types": "^13.346.0-beta.20250812191140",
    "globals": "^15.14.0",
    "happy-dom": "^16.5.3",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "marked": "^18.0.3"
  }
}
